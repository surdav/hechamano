DirectoryIndex index.html index.php

# Leverage Browser Caching by SG-Optimizer
<IfModule mod_expires.c>
    ExpiresActive on
  # CSS
    ExpiresByType text/css                              "access plus 1 year"
  # JavaScript
    ExpiresByType application/javascript                "access plus 1 year"
    ExpiresByType application/x-javascript              "access plus 1 year"
  # Manifest files
    ExpiresByType application/x-web-app-manifest+json   "access plus 0 seconds"
    ExpiresByType text/cache-manifest                   "access plus 0 seconds"
  # Media
    ExpiresByType image/avif                            "access plus 1 year"
    ExpiresByType audio/ogg                             "access plus 1 year"
    ExpiresByType image/gif                             "access plus 1 year"
    ExpiresByType image/jpg                             "access plus 1 year"
    ExpiresByType image/jpeg                            "access plus 1 year"
    ExpiresByType image/png                             "access plus 1 year"
    ExpiresByType image/svg                             "access plus 1 year"
    ExpiresByType image/svg+xml                         "access plus 1 year"
    ExpiresByType image/webp                            "access plus 1 year"
    ExpiresByType video/mp4                             "access plus 1 year"
    ExpiresByType video/ogg                             "access plus 1 year"
    ExpiresByType video/webm                            "access plus 1 year"
    ExpiresByType image/x-icon                          "access plus 1 year"
    ExpiresByType application/pdf                       "access plus 1 year"
    ExpiresByType application/x-shockwave-flash         "access plus 1 year"
  # XML
    ExpiresByType text/xml                              "access plus 0 seconds"
    ExpiresByType application/xml                       "access plus 0 seconds"
  # Web feeds
    ExpiresByType application/atom+xml                  "access plus 1 hour"
    ExpiresByType application/rss+xml                   "access plus 1 hour"
  # Web fonts
    ExpiresByType application/font-woff                 "access plus 1 year"
    ExpiresByType application/font-woff2                "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject         "access plus 1 year"
    ExpiresByType application/x-font-ttf                "access plus 1 year"
    ExpiresByType font/opentype                         "access plus 1 year"
</IfModule>
# END LBC

<IfModule mod_headers.c>
    <FilesMatch "\.(avif|css|gif|jpg|jpeg|js|png|svg|webp|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>





# GZIP enabled by SG-Optimizer
<IfModule mod_deflate.c>
    <IfModule mod_filter.c>
       AddOutputFilterByType DEFLATE "application/atom+xml" \
          "application/javascript" \
          "application/json" \
          "application/ld+json" \
          "application/manifest+json" \
          "application/rdf+xml" \
          "application/rss+xml" \
          "application/schema+json" \
          "application/vnd.geo+json" \
          "application/vnd.ms-fontobject" \
          "application/x-font-ttf" \
          "application/x-javascript" \
          "application/x-web-app-manifest+json" \
          "application/xhtml+xml" \
          "application/xml" \
          "font/eot" \
          "font/opentype" \
          "image/bmp" \
          "image/svg+xml" \
          "image/vnd.microsoft.icon" \
          "image/x-icon" \
          "text/cache-manifest" \
          "text/css" \
          "text/html" \
          "text/javascript" \
          "text/plain" \
          "text/vcard" \
          "text/vnd.rim.location.xloc" \
          "text/vtt" \
          "text/x-component" \
          "text/x-cross-domain-policy" \
          "text/xml"
    </IfModule>
</IfModule>
# END GZIP

#Begin Really Simple Security
<IfModule mod_rewrite.c>
RewriteEngine on
RewriteCond %{HTTPS} !=on [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

#End Really Simple Security
# BEGIN WordPress
# Las directivas (líneas) entre «BEGIN WordPress» y «END WordPress» son
# generadas dinámicamente y solo deberían ser modificadas mediante filtros de WordPress.
# Cualquier cambio en las directivas que hay entre esos marcadores serán sobrescritas.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>

# END WordPress

# Seguretat i catàstrofes
#
#
#
# MODIFICANT HTACCESS:
#
# Bloqueig al directori includes (core de wp)
# <IfModule mod_rewrite.c>
# 	RewriteEngine OnRewriteBase /
# 	RewriteRule ^wp-admin/includes/ - [F,L]
# 	RewriteRule !^wp-includes/ - [S=3]
# 	RewriteRule ^wp-includes/[^/]+\.php$ - [F,L]
# 	RewriteRule ^wp-includes/js/tinymce/langs/.+\.php - [F,L]
# 	RewriteRule ^wp-includes/theme-compat/ - [F,L]
# </IfModule>
#
#
#
# MODIFICANT HTACCESS:
#
# En un principi, dins de l’arxiu WP-CONFIG no hi té accés ningú ja que hi ha el pwd
# de la base de dades, el nom de la base de dades...
# localhost/wp-config.php emmagatzema TOT del nostre WP. Si falla quedarà visible.
#
# Bloqueig de l’accés a WP-CONFIG
 <Files wp-config.php>
 	Order Allow,Deny
 	Deny from all
 </Files>
#
#
#
# MODIFICANT HTACCESS:
# Podem forçar l’entrada de només una IP dins de “wp-login”
#
# Només entra la nostra IP al login (Skintech: 5.1.38.32, wordfence.com : 69.46.36.0/27)
#<Files wp-login.php>
#	Order Allow,Deny
#	Deny from all
#	Allow from 5.1.38.32
#	Allow from 69.46.36.0/27
#</Files>


# Protegim HTACCESS
 <Files ~ "^.*\.([Hh][Tt][Aa])">
 	Order allow,deny
 	Deny from all
 	Satisfy all
 </Files>
 

# MODIFICANT HTACCESS:
# 
# Ningú hauria de voler accedir a veure les plantilles i plugins instal·lats, així que
# perquè no li tanquem l’accés?
# 
# Tanquem l’accés a carpetes de themes i plugins
 RewriteCond %{REQUEST_URI} !^/wp-content/plugins/file/to/exclude\.php
 RewriteCond %{REQUEST_URI} !^/wp-content/plugins/directory/to/exclude/
 RewriteRule wp-content/plugins/(.*\.php)$ - [R=404,L]
 RewriteCond %{REQUEST_URI} !^/wp-content/themes/file/to/exclude\.php
 RewriteCond %{REQUEST_URI} !^/wp-content/themes/directory/to/exclude/
 RewriteRule wp-content/themes/(.*\.php)$ - [R=404,L]



# MODIFICANT HTACCESS:
# 
# Per últim, podem eliminar un arxiu “index.php” sense voler i com que no hi ha
# arxiu, veuriem totes les carpetes. Això podria crear una gran vulnerabilitat si
# ho deixem tot d’aquesta manera ja que si algun plugin o plantilla no té un
# index (o algun plugin l’ha esborrat) tindriem accés a tots els fitxers.
# 
# Prohibir veure els directoris
 Options -Indexes



# MODIFICANT HTACCESS:
# 
# I si ja volem acabar de rematar la jugada, dins de wp-admin també hi ha un
# htaccess, que tindrà prioritat amb heredada.
# Això significa que podem aplicar els mateixos permisos que hem fet fins ara a la
# carpeta wp-admin.
# 
# Entrada amb IP especifica.
# AuthUserFile /dev/null
# AuthGroupFile /dev/null
# AuthName "Access Control"
# AuthType Basicorder deny,allow
# Deny from all
# Allow from 5.1.38.32



# MODIFICANT WP-CONFIG.PHP:
# 
# Aquest arxiu és un dels que conté més informació crítica i confidencial. Entrarem en
# aquest arxiu per tal de convertir el nostre Wordpress en un Wordpress SEGUR.
# Hi podem trobar informació com la nostra IP, el nom de la base de dades, la
# contrasenya, la codificació, les claus de seguretat, els prefixes de la base de
# dades... En definita, el necessari per deixar el nostre Wordpress sense res.
# 
# 	Deshabilitar l’editor (apariencia / editor i plugins / editor).
# define ('DISALLOW_FILE_EDIT', true);

# 	Deshabilitar errors, avisos o php alerts.
# define ( 'WP_DEBUG', false);

# 	Forçar SSL per tots
# define ('FORCE_SSL_LOGIN', true);
# define ('FORCE_SSL_ADMIN', true);
# 
# 
# ----------------------------------------------------------------------------------------
# ----------------------------------------------------------------------------------------
# 
# MODIFICANT BASE DE DADES:
# 
# Un dels processos més complexes. Molt de compte en fer canvis directament a la
# base de dades ja que un canvi mal fet pot deixar-nos la web inservible.
# Accedirem a la base de dades amb PHPmyAdmin.
# Si fem la pràctica d'instal·lar WordFence, veurem com les taules de la BBDD
# augmenten considerablement, però si l’esborrem, aquestes taules no
# desapareixen. Podem entrar a dins del PHPmyAdmin per fer-ho manualment.
# Modificació del prefix de la BBDD per augmentar la seguretat en cas que
# l'haguéssim deixat per defecte amb “wp_”. Si fem el canvi seleccionant les
# taules i fent “Reemplazar prefijo de tabla” recordem anar a wp-config per
# aplicar el canvi també.
# Còpia manual de les taules per si volem instal·lar algun plugin que no confiem
# del tot. Ho seleccionem tot i posem “copiar tabla con prefijo” i ens crearà el
# duplicat amb el prefix que li hem posat anteriorment.
# Visitem wp_users i substituim el “user_nicename” per tal que no sigui igual que
# “user_login” així evitem que si algú sap el nostre nicename tingui un pas fet.
